<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .page-hero {
    text-align: center;
    padding: 3rem 0 3.5rem;
    animation: fadeUp 0.5s ease both;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--cyan);
    margin-bottom: 1.2rem;
    opacity: 0.85;
  }

  .page-hero h1 {
    font-family: var(--display);
    font-size: clamp(2.2rem, 5vw, 3.6rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 0.8rem;
  }

  .page-hero h1 span { color: var(--cyan); }

  .page-hero p {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin-bottom: 0;
  }

  /* PRICING CARDS */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    max-width: 780px;
    margin: 0 auto 4rem;
    animation: fadeUp 0.5s 0.1s ease both;
  }

  @media (max-width: 600px) {
    .pricing-grid { grid-template-columns: 1fr; }
  }

  .plan-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.8rem;
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
    position: relative;
    overflow: hidden;
  }

  .plan-card.pro {
    border-color: var(--violet);
    background: linear-gradient(160deg, rgba(124,92,252,0.08) 0%, var(--surface) 60%);
  }

  .popular-badge {
    position: absolute;
    top: -1px; right: 1.4rem;
    background: var(--violet);
    color: #fff;
    font-family: var(--mono);
    font-size: 0.58rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.28rem 0.65rem;
    border-radius: 0 0 7px 7px;
  }

  .plan-tier {
    display: inline-flex;
    align-items: center;
    padding: 0.22rem 0.6rem;
    border-radius: 5px;
    font-family: var(--mono);
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    width: fit-content;
  }

  .plan-tier.free {
    background: var(--cyan-dim);
    color: var(--cyan);
    border: 1px solid rgba(0,229,176,0.2);
  }

  .plan-tier.pro {
    background: var(--violet-dim);
    color: var(--violet);
    border: 1px solid rgba(124,92,252,0.25);
    border-radius: 5px;
  }

  .plan-price {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .plan-amount {
    font-family: var(--display);
    font-size: 3rem;
    font-weight: 800;
    line-height: 1;
  }

  .plan-amount.free-color  { color: var(--cyan); }
  .plan-amount.pro-color   { color: var(--violet); }

  .plan-cadence {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .plan-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
    border-top: 1px solid var(--border);
    padding-top: 1rem;
  }

  /* FEATURES LIST */
  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: none;
    flex: 1;
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.82rem;
    color: var(--text);
    line-height: 1.4;
  }

  .plan-features li .check {
    flex-shrink: 0;
    margin-top: 1px;
  }

  .check-free { color: var(--cyan); }
  .check-pro  { color: var(--violet); }

  /* CTA BUTTON */
  .plan-btn {
    display: block;
    text-align: center;
    text-decoration: none;
    padding: 0.75rem;
    border-radius: 10px;
    font-size: 0.88rem;
    font-weight: 600;
    transition: opacity 0.2s, background 0.2s;
  }

  .plan-btn.ghost {
    border: 1px solid var(--border);
    color: var(--text);
    background: transparent;
  }

  .plan-btn.ghost:hover { border-color: var(--text-dim); }

  .plan-btn.filled {
    background: var(--violet);
    color: #fff;
  }

  .plan-btn.filled:hover { opacity: 0.85; }

  /* COMPARISON TABLE */
  .compare-section {
    margin-bottom: 4rem;
    animation: fadeUp 0.5s 0.2s ease both;
  }

  .section-label {
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-dim);
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .section-label::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  .compare-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.82rem;
  }

  .compare-table th {
    text-align: left;
    padding: 0.6rem 1rem;
    font-family: var(--mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
  }

  .compare-table th:not(:first-child) { text-align: center; }

  .compare-table td {
    padding: 0.8rem 1rem;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  .compare-table td:not(:first-child) { text-align: center; }

  .compare-table tr:last-child td { border-bottom: none; }

  .compare-table tr:hover td { background: rgba(255,255,255,0.02); }

  .t-yes-free  { color: var(--cyan); }
  .t-yes-pro   { color: var(--violet); }
  .t-no        { color: var(--text-dim); opacity: 0.4; }

  /* FAQ */
  .faq {
    margin-bottom: 4rem;
    animation: fadeUp 0.5s 0.25s ease both;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
    padding: 1.1rem 0;
  }

  .faq-q {
    font-size: 0.88rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.4rem;
  }

  .faq-a {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  /* CTA BOTTOM */
  .cta-section {
    text-align: center;
    padding: 3.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 16px;
    background: var(--surface);
    animation: fadeUp 0.5s 0.3s ease both;
  }

  .cta-section h2 {
    font-family: var(--display);
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 0.7rem;
  }

  .cta-section p {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin-bottom: 1.8rem;
  }

  .cta-buttons {
    display: flex;
    justify-content: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--violet);
    color: #fff;
    text-decoration: none;
    padding: 0.65rem 1.3rem;
    border-radius: 9px;
    font-size: 0.85rem;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-ghost {
    background: transparent;
    color: var(--text);
    text-decoration: none;
    padding: 0.65rem 1.3rem;
    border-radius: 9px;
    font-size: 0.85rem;
    border: 1px solid var(--border);
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: var(--text-dim); }
</style>

