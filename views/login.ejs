<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Sign in — Staark</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Bricolage+Grotesque:wght@700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #1f2421;
      --surface:   #243028;
      --surface2:  #2a3830;
      --border:    #2f3d36;
      --text:      #dce1de;
      --text-dim:  #9cc5a1;
      --violet:    #49a078;
      --violet-dim:rgba(73,160,120,0.14);
      --cyan:      #49a078;
      --red:       #e06070;
      --mono: 'Courier New', monospace;
      --sans: 'Inter', sans-serif;
      --display: 'Bricolage Grotesque', sans-serif;
    }

    html, body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    /* LAYOUT */
    .auth-wrap {
      position: relative;
      z-index: 1;
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1.5rem;
    }

    /* LOGO */
    .auth-logo {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      text-decoration: none;
      margin-bottom: 2.5rem;
    }

    .auth-logo .logo-icon {
      width: 34px; height: 34px;
      background: var(--violet);
      border-radius: 9px;
      display: flex; align-items: center; justify-content: center;
    }

    .auth-logo .logo-icon svg { width: 17px; height: 17px; fill: #fff; }

    .auth-logo .wordmark {
      font-family: var(--display);
      font-weight: 800;
      font-size: 1.1rem;
      color: #fff;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* CARD */
    .auth-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 2.2rem;
      width: 100%;
      max-width: 400px;
      animation: fadeUp 0.5s ease both;
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(14px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    .auth-card h1 {
      font-family: var(--display);
      font-size: 1.55rem;
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.01em;
      margin-bottom: 0.3rem;
    }

    .auth-card .subtitle {
      font-size: 0.82rem;
      color: var(--text-dim);
      margin-bottom: 1.8rem;
    }

    /* FORM */
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      margin-bottom: 1rem;
    }

    label {
      font-size: 0.78rem;
      font-weight: 500;
      color: var(--text);
    }

    input[type="email"],
    input[type="password"],
    input[type="text"] {
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 9px;
      padding: 0.65rem 0.9rem;
      font-size: 0.85rem;
      color: var(--text);
      font-family: var(--sans);
      width: 100%;
      outline: none;
      transition: border-color 0.2s;
    }

    input:focus {
      border-color: var(--violet);
    }

    input::placeholder { color: var(--text-dim); }

    .form-footer-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.4rem;
    }

    .remember {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.78rem;
      color: var(--text-dim);
      cursor: pointer;
    }

    .remember input[type="checkbox"] {
      width: 14px; height: 14px;
      accent-color: var(--violet);
    }

    .forgot-link {
      font-size: 0.78rem;
      color: var(--violet);
      text-decoration: none;
    }

    .forgot-link:hover { text-decoration: underline; }

    /* ERROR */
    .error-msg {
      background: rgba(224,96,112,0.08);
      border: 1px solid rgba(224,96,112,0.2);
      border-radius: 8px;
      padding: 0.6rem 0.9rem;
      font-size: 0.78rem;
      color: var(--red);
      margin-bottom: 1rem;
      display: none;
    }

    .error-msg.show { display: block; }

    /* SUBMIT */
    .btn-submit {
      width: 100%;
      background: var(--violet);
      color: #fff;
      border: none;
      border-radius: 10px;
      padding: 0.75rem;
      font-size: 0.9rem;
      font-weight: 600;
      font-family: var(--sans);
      cursor: pointer;
      transition: opacity 0.2s;
      margin-bottom: 1.4rem;
    }

    .btn-submit:hover { opacity: 0.85; }

    /* DIVIDER */
    .divider {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      margin-bottom: 1.4rem;
      font-size: 0.72rem;
      color: var(--text-dim);
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--border);
    }

    /* REGISTER LINK */
    .register-link {
      text-align: center;
      font-size: 0.8rem;
      color: var(--text-dim);
    }

    .register-link a {
      color: var(--violet);
      text-decoration: none;
      font-weight: 500;
    }

    .register-link a:hover { text-decoration: underline; }

    /* FOOTER */
    .auth-page-footer {
      position: relative;
      z-index: 1;
      text-align: center;
      padding: 1.2rem;
      font-size: 0.7rem;
      color: var(--text-dim);
    }

    .auth-page-footer a {
      color: var(--text-dim);
      text-decoration: none;
    }

    .auth-page-footer a:hover { color: var(--text); }
  </style>
</head>
<body>

  <div class="auth-wrap">

    <a class="auth-logo" href="https://staark-app.cloud">
      <div class="logo-icon">
        <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </div>
      <span class="wordmark">Staark</span>
    </a>

    <div class="auth-card">
      <h1>Welcome back</h1>
      <p class="subtitle">Sign in to your Staark account</p>

      <% if (typeof error !== 'undefined' && error) { %>
        <div class="error-msg show"><%= error %></div>
      <% } %>

      <form action="/login" method="POST">
        <div class="form-group">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@company.com" required autocomplete="email" />
        </div>

        <div class="form-group">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••" required autocomplete="current-password" />
        </div>

        <div class="form-footer-row">
          <label class="remember">
            <input type="checkbox" name="remember" /> Remember me
          </label>
          <a href="/forgot-password" class="forgot-link">Forgot password?</a>
        </div>

        <button type="submit" class="btn-submit">Sign in →</button>
      </form>

      <div class="divider">or</div>

      <div class="register-link">
        Don't have an account? <a href="/register">Get started free</a>
      </div>
    </div>

  </div>

  <div class="auth-page-footer">
    <a href="https://staark-app.cloud">© 2026 Staark</a> ·
    <a href="#">Privacy</a> ·
    <a href="#">Terms</a>
  </div>

</body>
</html>
