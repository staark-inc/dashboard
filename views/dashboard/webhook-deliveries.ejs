<style>
  @keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }
  .del-wrap { max-width: 820px; animation: fadeUp 0.3s ease both; }

  .alert { padding: 0.65rem 1rem; border-radius: 7px; font-size: 0.78rem; margin-bottom: 1rem; border: 1px solid; }
  .alert-success { background: rgba(77,170,128,0.1); color: #6cd4a0; border-color: rgba(77,170,128,0.25); }

  .del-meta {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.8rem 1.1rem;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .del-url { font-family: var(--mono); font-size: 0.78rem; color: var(--text); flex:1; }
  .del-back { font-size: 0.75rem; }

  .delivery-list { display: flex; flex-direction: column; gap: 0.5rem; }

  .del-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .del-card-header {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    padding: 0.75rem 1rem;
    cursor: pointer;
    user-select: none;
  }
  .del-card-header:hover { background: var(--surface2); }

  .del-status {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 0.18rem 0.55rem;
    border-radius: 5px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    flex-shrink: 0;
  }
  .del-status.success { background: rgba(77,170,128,0.15); color: #6cd4a0; }
  .del-status.failed  { background: var(--red-dim); color: #f07080; }
  .del-status.pending { background: var(--surface2); color: var(--text-mid); }

  .del-event {
    font-family: var(--mono);
    font-size: 0.75rem;
    color: var(--text);
    flex: 1;
  }

  .del-time {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-mid);
    white-space: nowrap;
  }

  .del-http {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-mid);
    flex-shrink: 0;
  }

  .del-body {
    display: none;
    border-top: 1px solid var(--border);
    padding: 0.75rem 1rem;
    background: var(--bg);
  }

  .del-body.open { display: block; }

  .del-response {
    font-family: var(--mono);
    font-size: 0.72rem;
    color: var(--text-mid);
    white-space: pre-wrap;
    word-break: break-all;
    margin-bottom: 0.6rem;
    max-height: 120px;
    overflow: auto;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-mid);
    font-size: 0.8rem;
  }

  .pagination { display: flex; gap: 0.5rem; margin-top: 1rem; justify-content: flex-end; align-items: center; }
  .pag-info { font-size: 0.7rem; color: var(--text-mid); font-family: var(--mono); margin-right: auto; }
  .btn-pg { font-size: 0.72rem; padding: 0.35rem 0.8rem; border-radius: 7px; text-decoration: none; font-weight: 600; border: 1px solid var(--border2); color: var(--text); background: var(--surface); transition: all 0.15s; }
  .btn-pg:hover { border-color: var(--violet); color: var(--violet); }
</style>

<div class="del-wrap">

  <% if (typeof success !== 'undefined' && success) { %><div class="alert alert-success"><%= success %></div><% } %>

  <div class="del-meta">
    <a href="/dashboard/webhooks" class="btn-sm ghost del-back">← Webhooks</a>
    <span class="del-url"><%= hook.url %></span>
    <span style="font-size:0.68rem;color:var(--text-mid);font-family:var(--mono)"><%= meta.total %> deliveries</span>
  </div>

  <% if (deliveries.length === 0) { %>
    <div class="empty-state">No deliveries yet. Events will appear here when webhooks fire.</div>
  <% } else { %>
    <div class="delivery-list">
      <% deliveries.forEach((d, i) => {
        const ts = new Date(d.delivered_at * 1000).toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit', second:'2-digit' });
      %>
        <div class="del-card">
          <div class="del-card-header" onclick="this.nextElementSibling.classList.toggle('open')">
            <span class="del-status <%= d.status %>"><%= d.status %></span>
            <span class="del-event"><%= d.event %></span>
            <span class="del-http"><%= d.http_status ?? '—' %></span>
            <span class="del-time"><%= ts %></span>
            <% if (d.duration_ms != null) { %><span style="font-size:0.65rem;color:var(--text-mid);font-family:var(--mono)"><%= d.duration_ms %>ms</span><% } %>
          </div>
          <div class="del-body">
            <div class="del-response"><%= d.response || '(no response body)' %></div>
            <form action="/dashboard/webhooks/<%= hook.id %>/deliveries/<%= d.id %>/redeliver" method="POST" style="display:inline">
              <button type="submit" class="btn-sm ghost" style="font-size:0.7rem;padding:0.28rem 0.65rem">↻ Redeliver</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>

    <% if (meta.total > meta.limit) { %>
      <div class="pagination">
        <span class="pag-info"><%= meta.offset + 1 %>–<%= Math.min(meta.offset + meta.limit, meta.total) %> of <%= meta.total %></span>
        <% if (meta.offset > 0) { %>
          <a href="?offset=<%= Math.max(0, meta.offset - meta.limit) %>" class="btn-pg">← Previous</a>
        <% } %>
        <% if (meta.offset + meta.limit < meta.total) { %>
          <a href="?offset=<%= meta.offset + meta.limit %>" class="btn-pg">Next →</a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>

<script>
// Remember open cards on redeliver redirect
document.querySelectorAll('.del-card-header').forEach(h => {
  h.addEventListener('click', () => {
    const body = h.nextElementSibling;
    body.classList.toggle('open');
  });
});
</script>
