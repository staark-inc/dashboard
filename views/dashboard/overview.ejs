<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* STATS */
  .ov-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.7rem;
    margin-bottom: 1.4rem;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.1rem;
    animation: fadeUp 0.35s ease both;
    transition: border-color 0.2s;
  }

  .stat-card:hover { border-color: var(--border2); }

  .stat-label {
    font-family: var(--mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-dim);
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .stat-value {
    font-family: var(--display);
    font-size: 1.75rem;
    font-weight: 800;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .stat-value.violet { color: var(--violet); }
  .stat-value.cyan   { color: var(--cyan); }
  .stat-value.yellow { color: var(--yellow); }
  .stat-value.white  { color: #fff; }

  .stat-sub { font-size: 0.7rem; color: var(--text-dim); line-height: 1.4; }
  .stat-sub a { color: var(--violet); text-decoration: none; }
  .stat-sub a:hover { text-decoration: underline; }

  /* MAIN GRID */
  .ov-grid {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 1rem;
  }

  /* PANEL */
  .panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    animation: fadeUp 0.35s ease both;
  }

  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }

  .panel-title {
    font-size: 0.8rem;
    font-weight: 600;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .panel-count {
    font-family: var(--mono);
    font-size: 0.6rem;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: var(--surface2);
    color: var(--text-dim);
    border: 1px solid var(--border);
  }

  .panel-link {
    font-size: 0.72rem;
    color: var(--violet);
    text-decoration: none;
    opacity: 0.8;
  }
  .panel-link:hover { opacity: 1; text-decoration: underline; }

  /* PROJECT ROWS */
  .project-row {
    display: grid;
    grid-template-columns: 8px 1fr auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.12s;
    cursor: pointer;
  }

  .project-row:last-child { border-bottom: none; }
  .project-row:hover { background: var(--surface2); }

  .project-row-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .project-row-info { min-width: 0; }

  .project-row-name {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.2rem;
  }

  .project-row-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .project-row-tasks {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--text-dim);
  }

  .progress-mini {
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    overflow: hidden;
    width: 60px;
    flex-shrink: 0;
  }

  .progress-mini-fill {
    height: 100%;
    border-radius: 2px;
    background: var(--cyan);
    transition: width 0.5s ease;
  }

  .project-row-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-shrink: 0;
  }

  .vis-badge {
    font-family: var(--mono);
    font-size: 0.55rem;
    padding: 0.1rem 0.38rem;
    border-radius: 3px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .vis-badge.public  { background: var(--cyan-dim);   color: var(--cyan);   border: 1px solid rgba(0,229,176,0.2); }
  .vis-badge.private { background: var(--violet-dim); color: var(--violet); border: 1px solid rgba(124,92,252,0.2); }

  .project-row-actions {
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .project-row:hover .project-row-actions { opacity: 1; }

  .row-action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px; height: 24px;
    border-radius: 5px;
    border: 1px solid var(--border2);
    background: transparent;
    cursor: pointer;
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.12s;
  }

  .row-action-btn:hover { background: var(--surface3); color: var(--text); border-color: var(--text-dim); }
  .row-action-btn.del:hover { background: var(--red-dim); color: var(--red); border-color: rgba(255,77,106,0.3); }

  .add-project-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.1rem;
    text-decoration: none;
    color: var(--text-dim);
    font-size: 0.8rem;
    transition: background 0.12s, color 0.12s;
    border-top: 1px dashed var(--border2);
  }

  .add-project-row:hover { background: var(--surface2); color: var(--violet); }

  /* KEY ROWS */
  .key-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.75rem 1.1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
  }

  .key-row:last-child { border-bottom: none; }

  .key-name { font-weight: 600; color: var(--text); font-size: 0.8rem; }

  .key-preview {
    font-family: var(--mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    background: var(--surface2);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    margin-top: 0.15rem;
  }

  .status-dot {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--mono);
    font-size: 0.58rem;
    padding: 0.12rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
  }

  .status-dot .pip { width: 5px; height: 5px; border-radius: 50%; background: currentColor; }
  .status-dot.active  { color: var(--cyan);  background: var(--cyan-dim);  border: 1px solid rgba(0,229,176,0.2); }
  .status-dot.revoked { color: var(--red);   background: var(--red-dim);   border: 1px solid rgba(255,77,106,0.2); }

  .empty-state {
    padding: 2.5rem 1.2rem;
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .empty-state a { color: var(--violet); text-decoration: none; }
  .empty-state a:hover { text-decoration: underline; }

  /* PLAN CARD */
  .plan-card {
    background: linear-gradient(135deg, rgba(124,92,252,0.12), rgba(124,92,252,0.04));
    border: 1px solid rgba(124,92,252,0.2);
    border-radius: 12px;
    padding: 1rem 1.1rem;
    animation: fadeUp 0.35s 0.15s ease both;
    text-align: center;
  }

  .plan-name {
    font-family: var(--display);
    font-size: 1.3rem;
    font-weight: 800;
    color: var(--violet);
    text-transform: capitalize;
    margin-bottom: 0.25rem;
  }

  .plan-label { font-size: 0.68rem; color: var(--text-dim); margin-bottom: 0.8rem; }

  .plan-upgrade {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: var(--violet);
    color: #fff;
    text-decoration: none;
    border-radius: 7px;
    padding: 0.38rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 600;
    transition: opacity 0.15s;
  }

  .plan-upgrade:hover { opacity: 0.85; }
</style>

<%
  const completionRate = totalTasks > 0 ? Math.round((doneTasks / totalTasks) * 100) : 0;
  const activeKeys = keys.filter(k => !k.revokedAt).length;
%>

<!-- STATS -->
<div class="ov-stats">
  <div class="stat-card" style="animation-delay:0s">
    <div class="stat-label">Projects</div>
    <div class="stat-value violet"><%= projects.length %></div>
    <div class="stat-sub"><a href="/dashboard/projects">View all →</a></div>
  </div>
  <div class="stat-card" style="animation-delay:0.04s">
    <div class="stat-label">Total tasks</div>
    <div class="stat-value yellow"><%= totalTasks %></div>
    <div class="stat-sub">across all projects</div>
  </div>
  <div class="stat-card" style="animation-delay:0.08s">
    <div class="stat-label">Completed</div>
    <div class="stat-value cyan"><%= doneTasks %></div>
    <div class="stat-sub"><%= completionRate %>% completion rate</div>
  </div>
  <div class="stat-card" style="animation-delay:0.12s">
    <div class="stat-label">API Keys</div>
    <div class="stat-value white"><%= activeKeys %></div>
    <div class="stat-sub"><a href="/dashboard/keys">Manage →</a></div>
  </div>
</div>

<!-- MAIN GRID -->
<div class="ov-grid">

  <!-- LEFT: Projects -->
  <div class="panel" style="animation-delay:0.16s">
    <div class="panel-header">
      <span class="panel-title">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
        </svg>
        Projects
        <span class="panel-count"><%= projects.length %></span>
      </span>
      <a href="/dashboard/projects" class="panel-link">Manage →</a>
    </div>
    <% if (projects.length === 0) { %>
      <div class="empty-state">
        No projects yet.<br>
        <a href="/dashboard/projects/new">Create your first project →</a>
      </div>
    <% } else { %>
      <% projects.slice(0, 7).forEach(p => {
        const pct = p.taskCount > 0 ? Math.round((p.doneCount / p.taskCount) * 100) : 0;
      %>
        <div class="project-row" onclick="window.location='/dashboard/projects/<%= p.id %>'">
          <div class="project-row-dot" style="background:<%= p.color || 'var(--violet)' %>"></div>
          <div class="project-row-info">
            <div class="project-row-name"><%= p.name %></div>
            <div class="project-row-meta">
              <span class="project-row-tasks"><%= p.taskCount %> task<%= p.taskCount !== 1 ? 's' : '' %></span>
              <% if (p.taskCount > 0) { %>
                <div class="progress-mini">
                  <div class="progress-mini-fill" style="width:<%= pct %>%"></div>
                </div>
                <span class="project-row-tasks"><%= pct %>%</span>
              <% } %>
            </div>
          </div>
          <div class="project-row-right">
            <span class="vis-badge <%= p.visibility || 'private' %>"><%= p.visibility || 'private' %></span>
            <div class="project-row-actions">
              <a href="/dashboard/projects/<%= p.id %>/edit" class="row-action-btn" title="Edit"
                 onclick="event.stopPropagation()">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                </svg>
              </a>
              <button class="row-action-btn del" title="Delete"
                      onclick="event.stopPropagation(); openConfirm('/dashboard/projects/<%= p.id %>/delete', '<%= p.name.replace(/'/g, `\\'`) %>', 'All tasks in this project will be permanently deleted.')">
                <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="3 6 5 6 21 6"/>
                  <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
                  <path d="M10 11v6"/><path d="M14 11v6"/>
                  <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
                </svg>
              </button>
            </div>
          </div>
        </div>
      <% }) %>
      <a href="/dashboard/projects/new" class="add-project-row">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        New project
      </a>
    <% } %>
  </div>

  <!-- RIGHT COLUMN -->
  <div style="display:flex;flex-direction:column;gap:1rem">

    <!-- Plan -->
    <div class="plan-card">
      <div class="plan-label" style="margin-bottom:0.4rem;font-size:0.6rem;text-transform:uppercase;letter-spacing:0.1em">Current plan</div>
      <div class="plan-name"><%= typeof user !== 'undefined' && user.plan ? user.plan : 'Free' %></div>
      <div class="plan-label">Upgrade for more projects & keys</div>
      <a href="/pricing" class="plan-upgrade">Upgrade plan →</a>
    </div>

    <!-- API Keys -->
    <div class="panel" style="animation-delay:0.2s">
      <div class="panel-header">
        <span class="panel-title">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6M15.5 7.5l3 3L22 7l-3-3"/>
          </svg>
          API Keys
        </span>
        <a href="/dashboard/keys" class="panel-link">Manage →</a>
      </div>
      <% if (keys.length === 0) { %>
        <div class="empty-state" style="padding:1.5rem">
          <a href="/dashboard/keys">Generate your first key →</a>
        </div>
      <% } else { %>
        <% keys.slice(0, 4).forEach(k => { %>
          <div class="key-row">
            <div>
              <div class="key-name"><%= k.name || 'Unnamed key' %></div>
              <div class="key-preview">sk_live_••••<%= k.lastFour || '••••' %></div>
            </div>
            <span class="status-dot <%= k.revokedAt ? 'revoked' : 'active' %>">
              <span class="pip"></span>
              <%= k.revokedAt ? 'revoked' : 'active' %>
            </span>
          </div>
        <% }) %>
        <% if (keys.length > 4) { %>
          <div style="padding:0.6rem 1.1rem;font-size:0.7rem;color:var(--text-dim);text-align:center;border-top:1px solid var(--border)">
            <a href="/dashboard/keys" style="color:var(--violet);text-decoration:none">+<%= keys.length - 4 %> more →</a>
          </div>
        <% } %>
      <% } %>
    </div>

  </div>

</div>
