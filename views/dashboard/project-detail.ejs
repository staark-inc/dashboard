<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── PROJECT HEADER ── */
  .project-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.2rem;
    animation: fadeUp 0.35s ease both;
  }

  .project-title-wrap {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    flex: 1;
    min-width: 0;
  }

  .project-color-dot {
    width: 11px; height: 11px;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 5px;
  }

  .project-name {
    font-family: var(--display);
    font-size: 1.35rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.01em;
    line-height: 1.2;
    margin-bottom: 0.25rem;
  }

  .project-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
    line-height: 1.55;
  }

  .project-meta-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .meta-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.57rem;
    padding: 0.12rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border: 1px solid;
  }

  .meta-pill.private   { color: var(--violet);   background: var(--violet-dim); border-color: rgba(124,92,252,0.2); }
  .meta-pill.public    { color: var(--cyan);     background: var(--cyan-dim);   border-color: rgba(0,229,176,0.2); }
  .meta-pill.active    { color: var(--cyan);     background: var(--cyan-dim);   border-color: rgba(0,229,176,0.2); }
  .meta-pill.archived  { color: var(--text-dim); background: transparent;       border-color: var(--border2); }
  .meta-pill.completed { color: var(--yellow);   background: rgba(245,197,66,0.1); border-color: rgba(245,197,66,0.2); }

  .meta-date {
    font-family: var(--mono);
    font-size: 0.62rem;
    color: var(--text-dim);
  }

  .project-actions {
    display: flex;
    gap: 0.4rem;
    flex-shrink: 0;
    align-items: flex-start;
  }

  /* ── STATS ── */
  .task-stats {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.6rem;
    margin-bottom: 1.1rem;
    animation: fadeUp 0.35s 0.04s ease both;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0.8rem 0.9rem;
    transition: border-color 0.2s;
  }

  .stat-card:hover { border-color: var(--border2); }

  .stat-label {
    font-family: var(--mono);
    font-size: 0.56rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    margin-bottom: 0.3rem;
  }

  .stat-value {
    font-family: var(--display);
    font-size: 1.45rem;
    font-weight: 800;
    line-height: 1;
  }

  .stat-value.violet { color: var(--violet); }
  .stat-value.cyan   { color: var(--cyan); }
  .stat-value.yellow { color: var(--yellow); }
  .stat-value.red    { color: var(--red); }
  .stat-value.white  { color: #fff; }

  /* ── TOOLBAR ── */
  .tasks-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.8rem;
    animation: fadeUp 0.35s 0.08s ease both;
    flex-wrap: wrap;
  }

  .filters { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .filter-btn {
    padding: 0.28rem 0.65rem;
    border-radius: 6px;
    font-size: 0.72rem;
    font-weight: 500;
    font-family: var(--sans);
    cursor: pointer;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--text-dim);
    transition: all 0.12s;
    text-decoration: none;
    white-space: nowrap;
  }

  .filter-btn:hover, .filter-btn.active {
    border-color: var(--violet);
    color: var(--violet);
    background: var(--violet-dim);
  }

  /* ── TASKS TABLE ── */
  .tasks-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    animation: fadeUp 0.35s 0.12s ease both;
  }

  .task-row {
    display: grid;
    grid-template-columns: 9px 1fr auto auto auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.72rem 1.1rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }

  .task-row:last-child { border-bottom: none; }
  .task-row:hover { background: var(--surface2); }
  .task-row:hover .task-actions { opacity: 1; }

  .task-row.header {
    font-family: var(--mono);
    font-size: 0.56rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    background: var(--surface);
    padding: 0.5rem 1.1rem;
    border-bottom: 1px solid var(--border);
  }

  .task-row.done-row .task-title-text {
    text-decoration: line-through;
    opacity: 0.45;
  }

  .priority-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .priority-dot.urgent { background: var(--red); }
  .priority-dot.high   { background: var(--orange); }
  .priority-dot.medium { background: var(--violet); }
  .priority-dot.low    { background: var(--text-dim); }

  .task-title-cell {
    min-width: 0;
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .task-title-text {
    font-size: 0.81rem;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .task-tags { display: inline-flex; gap: 0.2rem; flex-shrink: 0; }

  .tag {
    font-family: var(--mono);
    font-size: 0.54rem;
    padding: 0.08rem 0.32rem;
    border-radius: 3px;
    background: var(--surface2);
    color: var(--text-dim);
    border: 1px solid var(--border);
    white-space: nowrap;
  }

  /* STATUS PILL */
  .status-pill {
    display: inline-flex;
    align-items: center;
    font-family: var(--mono);
    font-size: 0.56rem;
    padding: 0.12rem 0.42rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    border: 1px solid;
    cursor: pointer;
    transition: opacity 0.15s;
    user-select: none;
  }

  .status-pill:hover { opacity: 0.75; }

  .status-pill.todo        { color: var(--text-dim); background: transparent;           border-color: var(--border2); }
  .status-pill.in_progress { color: var(--yellow);   background: rgba(245,197,66,0.1);  border-color: rgba(245,197,66,0.2); }
  .status-pill.done        { color: var(--cyan);     background: var(--cyan-dim);       border-color: rgba(0,229,176,0.2); }
  .status-pill.cancelled   { color: var(--red);      background: var(--red-dim);        border-color: rgba(255,77,106,0.2); }

  /* DUE */
  .task-due {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--text-dim);
    white-space: nowrap;
  }

  .task-due.overdue { color: var(--red); }

  /* PRIORITY TEXT */
  .priority-text {
    font-family: var(--mono);
    font-size: 0.6rem;
    white-space: nowrap;
  }

  .priority-text.urgent { color: var(--red); }
  .priority-text.high   { color: var(--orange); }
  .priority-text.medium { color: var(--violet); }
  .priority-text.low    { color: var(--text-dim); }

  /* ACTIONS */
  .task-actions {
    display: flex;
    gap: 0.25rem;
    opacity: 0;
    transition: opacity 0.12s;
    flex-shrink: 0;
  }

  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 25px; height: 25px;
    border-radius: 5px;
    border: 1px solid var(--border2);
    background: transparent;
    cursor: pointer;
    color: var(--text-dim);
    text-decoration: none;
    transition: all 0.12s;
  }

  .action-btn:hover { background: var(--surface3); color: var(--text); border-color: var(--text-dim); }
  .action-btn.del:hover { background: var(--red-dim); color: var(--red); border-color: rgba(255,77,106,0.3); }

  /* EMPTY */
  .empty-state {
    padding: 3rem 1.2rem;
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
  }

  .empty-state a { color: var(--violet); text-decoration: none; }
</style>

<%
  const allTasks      = tasks;
  const todoTasks     = allTasks.filter(t => t.status === 'todo');
  const inProgTasks   = allTasks.filter(t => t.status === 'in_progress');
  const doneTasks     = allTasks.filter(t => t.status === 'done');
  const cancelledTasks = allTasks.filter(t => t.status === 'cancelled');

  const filterStatus  = typeof currentFilter !== 'undefined' ? currentFilter : 'all';
  const filteredTasks = filterStatus === 'all' ? allTasks : allTasks.filter(t => t.status === filterStatus);
  const createdDate   = project.created_at
    ? new Date(project.created_at * 1000).toLocaleDateString('en-GB')
    : project.createdAt ? new Date(project.createdAt).toLocaleDateString('en-GB') : '—';

  function isOverdue(due) {
    if (!due) return false;
    return new Date(due) < new Date();
  }

  const completionPct = allTasks.length > 0 ? Math.round((doneTasks.length / allTasks.length) * 100) : 0;
%>

<!-- PROJECT HEADER -->
<div class="project-header">
  <div class="project-title-wrap">
    <div class="project-color-dot" style="background:<%= project.color || 'var(--violet)' %>"></div>
    <div style="min-width:0">
      <div class="project-name"><%= project.name %></div>
      <% if (project.description) { %>
        <div class="project-desc"><%= project.description %></div>
      <% } %>
      <div class="project-meta-row">
        <span class="meta-pill <%= project.visibility %>"><%= project.visibility %></span>
        <span class="meta-pill <%= project.status %>"><%= project.status %></span>
        <span class="meta-date">Created <%= createdDate %></span>
        <% if (completionPct > 0) { %>
          <span class="meta-date">· <%= completionPct %>% complete</span>
        <% } %>
      </div>
    </div>
  </div>
  <div class="project-actions">
    <a href="/dashboard/projects/<%= project.id %>/tasks/new" class="btn-sm primary">
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      New task
    </a>
    <a href="/dashboard/projects/<%= project.id %>/edit" class="btn-sm ghost">Edit</a>
    <button class="btn-sm danger"
            onclick="openConfirm('/dashboard/projects/<%= project.id %>/delete', '<%= project.name.replace(/'/g, `\\'`) %>', 'All tasks in this project will be permanently deleted.')">
      Delete
    </button>
  </div>
</div>

<!-- STATS -->
<div class="task-stats">
  <div class="stat-card">
    <div class="stat-label">Total</div>
    <div class="stat-value violet"><%= allTasks.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">To do</div>
    <div class="stat-value white"><%= todoTasks.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">In progress</div>
    <div class="stat-value yellow"><%= inProgTasks.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Done</div>
    <div class="stat-value cyan"><%= doneTasks.length %></div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Cancelled</div>
    <div class="stat-value red"><%= cancelledTasks.length %></div>
  </div>
</div>

<!-- TOOLBAR -->
<div class="tasks-toolbar">
  <div class="filters">
    <a href="?filter=all"         class="filter-btn <%= filterStatus === 'all'         ? 'active' : '' %>">All <span style="opacity:0.6">(<%= allTasks.length %>)</span></a>
    <a href="?filter=todo"        class="filter-btn <%= filterStatus === 'todo'        ? 'active' : '' %>">Todo <span style="opacity:0.6">(<%= todoTasks.length %>)</span></a>
    <a href="?filter=in_progress" class="filter-btn <%= filterStatus === 'in_progress' ? 'active' : '' %>">In progress <span style="opacity:0.6">(<%= inProgTasks.length %>)</span></a>
    <a href="?filter=done"        class="filter-btn <%= filterStatus === 'done'        ? 'active' : '' %>">Done <span style="opacity:0.6">(<%= doneTasks.length %>)</span></a>
    <a href="?filter=cancelled"   class="filter-btn <%= filterStatus === 'cancelled'   ? 'active' : '' %>">Cancelled <span style="opacity:0.6">(<%= cancelledTasks.length %>)</span></a>
  </div>
  <a href="/dashboard/projects/<%= project.id %>/tasks/new" class="btn-sm primary">
    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round">
      <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
    </svg>
    Add task
  </a>
</div>

<!-- TASKS TABLE -->
<div class="tasks-panel">
  <div class="task-row header">
    <span></span>
    <span>Title</span>
    <span>Status</span>
    <span>Due</span>
    <span>Priority</span>
    <span></span>
  </div>

  <% if (filteredTasks.length === 0) { %>
    <div class="empty-state">
      <% if (filterStatus !== 'all') { %>
        No <%= filterStatus.replace('_', ' ') %> tasks.
        <a href="?filter=all">Show all →</a>
      <% } else { %>
        No tasks yet.
        <a href="/dashboard/projects/<%= project.id %>/tasks/new">Add the first one →</a>
      <% } %>
    </div>
  <% } else { %>
    <% filteredTasks.forEach(task => { %>
      <div class="task-row <%= task.status === 'done' ? 'done-row' : '' %>">

        <span class="priority-dot <%= task.priority || 'medium' %>"></span>

        <span class="task-title-cell">
          <span class="task-title-text"><%= task.title %></span>
          <% if (task.tags && task.tags.length > 0) { %>
            <span class="task-tags">
              <% task.tags.slice(0, 2).forEach(tag => { %>
                <span class="tag"><%= tag %></span>
              <% }) %>
              <% if (task.tags.length > 2) { %>
                <span class="tag">+<%= task.tags.length - 2 %></span>
              <% } %>
            </span>
          <% } %>
        </span>

        <span class="status-pill <%= task.status %>"
              onclick="cycleStatus('<%= project.id %>', '<%= task.id %>', '<%= task.title.replace(/'/g, `\\'`) %>', '<%= task.priority || 'medium' %>', '<%= task.status %>')"
              title="Click to change status">
          <%= task.status.replace('_', ' ') %>
        </span>

        <span class="task-due <%= isOverdue(task.due_date) && task.status !== 'done' ? 'overdue' : '' %>">
          <%= task.due_date ? new Date(task.due_date).toLocaleDateString('en-GB') : '—' %>
        </span>

        <span class="priority-text <%= task.priority || 'medium' %>"><%= task.priority || 'medium' %></span>

        <span class="task-actions">
          <a href="/dashboard/projects/<%= project.id %>/tasks/<%= task.id %>/edit"
             class="action-btn" title="Edit task">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </a>
          <button class="action-btn del" title="Delete task"
                  onclick="openConfirm('/dashboard/projects/<%= project.id %>/tasks/<%= task.id %>/delete', '<%= task.title.replace(/'/g, `\\'`) %>', 'This task will be permanently deleted.')">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="3 6 5 6 21 6"/>
              <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/>
              <path d="M10 11v6"/><path d="M14 11v6"/>
              <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/>
            </svg>
          </button>
        </span>

      </div>
    <% }) %>
  <% } %>
</div>

<script>
  const STATUS_CYCLE = ['todo', 'in_progress', 'done', 'cancelled'];

  function cycleStatus(projectId, taskId, title, priority, currentStatus) {
    const idx  = STATUS_CYCLE.indexOf(currentStatus);
    const next = STATUS_CYCLE[(idx + 1) % STATUS_CYCLE.length];

    const form = document.createElement('form');
    form.method = 'POST';
    form.action = `/dashboard/projects/${projectId}/tasks/${taskId}/edit`;

    const fields = { title, priority, status: next, tags: '[]' };
    for (const [k, v] of Object.entries(fields)) {
      const input = document.createElement('input');
      input.type = 'hidden'; input.name = k; input.value = v;
      form.appendChild(input);
    }

    document.body.appendChild(form);
    form.submit();
  }
</script>
