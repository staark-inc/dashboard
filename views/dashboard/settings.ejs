<style>
  @keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

  .settings-wrap { max-width: 580px; animation: fadeUp 0.3s ease both; }

  .settings-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 1rem;
    overflow: hidden;
  }

  .section-header {
    padding: 1rem 1.2rem 0.8rem;
    border-bottom: 1px solid var(--border);
  }

  .section-title {
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 0.2rem;
  }

  .section-desc {
    font-size: 0.72rem;
    color: var(--text-mid);
  }

  .section-body {
    padding: 1rem 1.2rem;
  }

  .status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
  }

  .status-badge.on  { background: rgba(77,170,128,0.15); color: #6cd4a0; border: 1px solid rgba(77,170,128,0.3); }
  .status-badge.off { background: var(--surface2); color: var(--text-mid); border: 1px solid var(--border); }

  .status-dot { width: 6px; height: 6px; border-radius: 50%; }
  .status-dot.on  { background: #6cd4a0; }
  .status-dot.off { background: var(--text-mid); }

  .alert {
    padding: 0.65rem 1rem;
    border-radius: 7px;
    font-size: 0.78rem;
    margin-bottom: 1rem;
    border: 1px solid;
  }
  .alert-success { background: rgba(77,170,128,0.1); color: #6cd4a0; border-color: rgba(77,170,128,0.25); }
  .alert-error   { background: var(--red-dim); color: #f07080; border-color: rgba(224,96,112,0.25); }

  .form-inline { display: flex; align-items: center; gap: 0.5rem; }

  .input-sm {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.38rem 0.7rem;
    font-size: 0.8rem;
    color: var(--text);
    font-family: var(--mono);
    width: 140px;
    letter-spacing: 0.1em;
    transition: border-color 0.15s;
  }
  .input-sm:focus { outline: none; border-color: var(--violet); }
  .input-sm::placeholder { color: var(--text-mid); letter-spacing: normal; }

  .oauth-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }

  .oauth-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 600;
    border: 1px solid var(--border2);
    background: var(--surface2);
    color: var(--text);
    transition: border-color 0.15s, background 0.15s;
  }
  .oauth-btn:hover { border-color: var(--violet); background: var(--violet-dim); }
</style>

<div class="settings-wrap">

  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

  <!-- 2FA -->
  <div class="settings-section">
    <div class="section-header">
      <div class="section-title">Two-Factor Authentication</div>
      <div class="section-desc">Protect your account with a time-based one-time password (TOTP)</div>
    </div>
    <div class="section-body">
      <div class="status-row">
        <span class="status-badge <%= totp_enabled ? 'on' : 'off' %>">
          <span class="status-dot <%= totp_enabled ? 'on' : 'off' %>"></span>
          <%= totp_enabled ? 'Enabled' : 'Disabled' %>
        </span>

        <% if (!totp_enabled) { %>
          <form action="/dashboard/settings/totp/setup" method="POST">
            <button type="submit" class="btn-sm primary">Enable 2FA</button>
          </form>
        <% } else { %>
          <form action="/dashboard/settings/totp/disable" method="POST" class="form-inline">
            <input type="text" name="code" class="input-sm" placeholder="000 000" maxlength="6" autocomplete="one-time-code" required />
            <button type="submit" class="btn-sm danger">Disable</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>

  <!-- OAuth -->
  <div class="settings-section">
    <div class="section-header">
      <div class="section-title">Connected Accounts</div>
      <div class="section-desc">Sign in faster with your existing accounts</div>
    </div>
    <div class="section-body">
      <div class="oauth-grid">
        <a href="https://api.staark-app.cloud/v1/auth/oauth/google" class="oauth-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Google
        </a>
        <a href="https://api.staark-app.cloud/v1/auth/oauth/github" class="oauth-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          GitHub
        </a>
      </div>
    </div>
  </div>

</div>
