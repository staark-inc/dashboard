<style>
  @keyframes fadeUp { from { opacity:0; transform:translateY(10px); } to { opacity:1; transform:translateY(0); } }

  .wh-wrap { max-width: 820px; animation: fadeUp 0.3s ease both; }

  .alert { padding: 0.65rem 1rem; border-radius: 7px; font-size: 0.78rem; margin-bottom: 1rem; border: 1px solid; }
  .alert-success { background: rgba(77,170,128,0.1); color: #6cd4a0; border-color: rgba(77,170,128,0.25); }
  .alert-error   { background: var(--red-dim); color: #f07080; border-color: rgba(224,96,112,0.25); }

  /* Create form */
  .create-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-bottom: 1.4rem;
    overflow: hidden;
  }

  .create-header {
    padding: 0.85rem 1.2rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
  }

  .create-body { padding: 1.1rem 1.2rem; }

  .form-row { display: flex; gap: 0.7rem; align-items: flex-end; flex-wrap: wrap; margin-bottom: 0.9rem; }

  .field { display: flex; flex-direction: column; gap: 0.3rem; }
  .field label { font-size: 0.68rem; font-weight: 600; color: var(--text-mid); text-transform: uppercase; letter-spacing: 0.06em; }

  .input-field {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 7px;
    padding: 0.42rem 0.75rem;
    font-size: 0.8rem;
    color: var(--text);
    font-family: var(--sans);
    transition: border-color 0.15s;
    min-width: 220px;
  }
  .input-field:focus { outline: none; border-color: var(--violet); }
  .input-field::placeholder { color: var(--text-mid); }

  .events-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 0.9rem;
  }

  .event-check { display: none; }
  .event-label {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.68rem;
    font-family: var(--mono);
    padding: 0.22rem 0.55rem;
    border-radius: 5px;
    border: 1px solid var(--border);
    background: var(--surface2);
    color: var(--text-mid);
    cursor: pointer;
    transition: all 0.12s;
    user-select: none;
  }
  .event-check:checked + .event-label {
    background: rgba(77,170,128,0.15);
    color: #6cd4a0;
    border-color: rgba(77,170,128,0.4);
  }

  /* Hooks list */
  .hooks-list { display: flex; flex-direction: column; gap: 0.6rem; }

  .hook-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0.9rem 1.1rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: border-color 0.15s;
  }
  .hook-card:hover { border-color: var(--border2); }

  .hook-status {
    width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    background: #6cd4a0;
  }

  .hook-info { flex: 1; min-width: 0; }

  .hook-url {
    font-family: var(--mono);
    font-size: 0.78rem;
    color: var(--text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.25rem;
  }

  .hook-events {
    display: flex;
    gap: 0.3rem;
    flex-wrap: wrap;
  }

  .event-tag {
    font-family: var(--mono);
    font-size: 0.58rem;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: var(--surface2);
    color: var(--text-mid);
    border: 1px solid var(--border);
  }

  .hook-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text-mid);
    font-size: 0.8rem;
  }
</style>

<div class="wh-wrap">

  <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <% if (error)   { %><div class="alert alert-error"><%= error %></div><% } %>

  <!-- Create -->
  <div class="create-card">
    <div class="create-header">Add Webhook</div>
    <div class="create-body">
      <form action="/dashboard/webhooks" method="POST">
        <div class="form-row">
          <div class="field" style="flex:1">
            <label>Payload URL</label>
            <input type="url" name="url" class="input-field" placeholder="https://example.com/webhook" required style="width:100%" />
          </div>
          <div class="field">
            <label>Secret (optional)</label>
            <input type="text" name="secret" class="input-field" placeholder="signing secret" style="min-width:160px" />
          </div>
        </div>

        <div style="margin-bottom:0.6rem">
          <div style="font-size:0.68rem;font-weight:600;color:var(--text-mid);text-transform:uppercase;letter-spacing:0.06em;margin-bottom:0.5rem">Events</div>
          <div class="events-grid">
            <% validEvents.forEach(ev => { %>
              <input type="checkbox" name="events" value="<%= ev %>" id="ev-<%= ev.replace('.', '-') %>" class="event-check" checked />
              <label for="ev-<%= ev.replace('.', '-') %>" class="event-label"><%= ev %></label>
            <% }) %>
          </div>
        </div>

        <button type="submit" class="btn-sm primary">Create webhook</button>
      </form>
    </div>
  </div>

  <!-- List -->
  <% if (hooks.length === 0) { %>
    <div class="empty-state">No webhooks configured yet.</div>
  <% } else { %>
    <div class="hooks-list">
      <% hooks.forEach(hook => { %>
        <div class="hook-card">
          <span class="hook-status" title="Active"></span>
          <div class="hook-info">
            <div class="hook-url"><%= hook.url %></div>
            <div class="hook-events">
              <% (hook.events || []).slice(0, 6).forEach(ev => { %>
                <span class="event-tag"><%= ev %></span>
              <% }) %>
              <% if (hook.events?.length > 6) { %>
                <span class="event-tag">+<%= hook.events.length - 6 %> more</span>
              <% } %>
            </div>
          </div>
          <div class="hook-actions">
            <a href="/dashboard/webhooks/<%= hook.id %>/deliveries" class="btn-sm ghost">Deliveries</a>
            <form action="/dashboard/webhooks/<%= hook.id %>/delete" method="POST" style="display:inline">
              <button type="submit" class="btn-sm danger"
                onclick="return confirm('Delete this webhook?')">Delete</button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>

</div>
