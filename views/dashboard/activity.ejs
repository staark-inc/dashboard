<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .activity-wrap { max-width: 760px; animation: fadeUp 0.35s ease both; }

  .activity-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.6rem;
  }

  .activity-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .activity-count {
    font-size: 0.72rem;
    color: var(--text-mid);
    font-family: var(--mono, monospace);
    background: var(--surface2);
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    border: 1px solid var(--border);
  }

  /* ── TIMELINE ── */
  .timeline {
    position: relative;
    padding-left: 2.6rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 13px;
    top: 16px; bottom: 16px;
    width: 2px;
    background: linear-gradient(to bottom, var(--violet), rgba(77,170,128,0.1));
    border-radius: 2px;
  }

  /* ── ITEM CARD ── */
  .timeline-item {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius, 10px);
    padding: 0.9rem 1.1rem;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .timeline-item:hover {
    border-color: var(--border2);
    box-shadow: 0 4px 16px rgba(0,0,0,0.25);
  }

  /* ── DOT ── */
  .timeline-dot {
    position: absolute;
    left: -2.15rem;
    top: 0.95rem;
    width: 24px; height: 24px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 11px;
    font-weight: 700;
    z-index: 1;
  }

  .dot-key     { background: rgba(77,170,128,0.22);  color: #6cd4a0; border: 1.5px solid rgba(77,170,128,0.5); }
  .dot-user    { background: rgba(139,133,255,0.18); color: #a89eff; border: 1.5px solid rgba(139,133,255,0.45); }
  .dot-project { background: rgba(212,168,67,0.18);  color: #e8bb4a; border: 1.5px solid rgba(212,168,67,0.45); }
  .dot-task    { background: rgba(90,159,212,0.18);  color: #7bbde8; border: 1.5px solid rgba(90,159,212,0.45); }
  .dot-delete  { background: rgba(224,96,112,0.18);  color: #f07080; border: 1.5px solid rgba(224,96,112,0.45); }

  /* ── CONTENT ── */
  .item-top {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.35rem;
  }

  .timeline-action {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text);
    flex: 1;
  }

  .timeline-time {
    font-size: 0.68rem;
    color: var(--text-mid);
    font-family: var(--mono, monospace);
    white-space: nowrap;
  }

  /* ── CHIPS ROW ── */
  .timeline-chips {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .chip {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--mono, monospace);
    font-size: 0.68rem;
    padding: 0.18rem 0.5rem;
    border-radius: 5px;
    border: 1px solid var(--border2);
    font-weight: 500;
  }

  .chip-entity {
    background: rgba(77,170,128,0.1);
    color: #6cd4a0;
    border-color: rgba(77,170,128,0.25);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.6rem;
  }

  .chip-name {
    background: var(--surface2);
    color: var(--text);
    border-color: var(--border);
  }

  .chip-plan {
    background: rgba(212,168,67,0.12);
    color: #e8bb4a;
    border-color: rgba(212,168,67,0.3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.6rem;
  }

  /* ── EMPTY ── */
  .empty-timeline {
    text-align: center;
    padding: 4rem 1rem;
    font-size: 0.85rem;
    color: var(--text-mid);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius, 10px);
  }

  .empty-timeline .empty-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 0.75rem;
    opacity: 0.5;
  }

  /* ── PAGINATION ── */
  .pagination {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.4rem;
    justify-content: flex-end;
    align-items: center;
  }

  .pagination-info {
    font-size: 0.7rem;
    color: var(--text-mid);
    font-family: var(--mono, monospace);
    margin-right: auto;
  }

  .btn-sm {
    font-size: 0.72rem;
    padding: 0.38rem 0.9rem;
    border-radius: 7px;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid var(--border2);
    color: var(--text);
    background: var(--surface);
    cursor: pointer;
    transition: all 0.15s;
  }

  .btn-sm:hover {
    border-color: var(--violet);
    color: var(--violet);
    background: var(--violet-dim);
  }
</style>

<div class="activity-wrap">

  <div class="activity-header">
    <span class="activity-title">Activity Log</span>
    <span class="activity-count"><%= meta.total %> event<%= meta.total !== 1 ? 's' : '' %></span>
  </div>

  <% if (!logs || logs.length === 0) { %>
    <div class="empty-timeline">
      <span class="empty-icon">📋</span>
      No activity recorded yet.
    </div>
  <% } else { %>

  <div class="timeline">
    <% const ACTION_LABELS = {
      'key.generated':   'Generated API key',
      'key.revoked':     'Revoked API key',
      'user.login':      'Signed in',
      'user.register':   'Created account',
      'project.created': 'Created project',
      'project.updated': 'Updated project',
      'project.deleted': 'Deleted project',
      'task.created':    'Created task',
      'task.updated':    'Updated task',
      'task.deleted':    'Deleted task',
    };

    const ICONS = { key: '⚡', user: '◎', project: '▣', task: '✓' };
    %>

    <% logs.forEach(entry => {
      const cat    = entry.action.split('.')[0];
      const verb   = entry.action.split('.')[1] || '';
      const isDel  = verb === 'deleted' || verb === 'revoked';
      const dotCls = isDel ? 'dot-delete' : ('dot-' + cat);
      const label  = ACTION_LABELS[entry.action] || entry.action;
      const ts     = new Date(entry.created_at * 1000);
      const timeStr = ts.toLocaleString('en-GB', {
        day: '2-digit', month: 'short', year: 'numeric',
        hour: '2-digit', minute: '2-digit',
      });
      const icon = ICONS[cat] || '•';
    %>
      <div class="timeline-item">
        <div class="timeline-dot <%= dotCls %>"><%= icon %></div>

        <div class="item-top">
          <span class="timeline-action"><%= label %></span>
          <span class="timeline-time"><%= timeStr %></span>
        </div>

        <div class="timeline-chips">
          <% if (entry.entity_type) { %>
            <span class="chip chip-entity"><%= entry.entity_type %></span>
          <% } %>
          <% if (entry.details?.name) { %>
            <span class="chip chip-name"><%= entry.details.name %></span>
          <% } %>
          <% if (entry.details?.title) { %>
            <span class="chip chip-name"><%= entry.details.title %></span>
          <% } %>
          <% if (entry.details?.plan) { %>
            <span class="chip chip-plan"><%= entry.details.plan %></span>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>

  <% if (meta.total > meta.limit) { %>
    <div class="pagination">
      <span class="pagination-info">
        <%= meta.offset + 1 %>–<%= Math.min(meta.offset + meta.limit, meta.total) %> of <%= meta.total %>
      </span>
      <% if (meta.offset > 0) { %>
        <a href="/dashboard/activity?offset=<%= Math.max(0, meta.offset - meta.limit) %>" class="btn-sm">← Previous</a>
      <% } %>
      <% if (meta.offset + meta.limit < meta.total) { %>
        <a href="/dashboard/activity?offset=<%= meta.offset + meta.limit %>" class="btn-sm">Next →</a>
      <% } %>
    </div>
  <% } %>

  <% } %>
</div>
