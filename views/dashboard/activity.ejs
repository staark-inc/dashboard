<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .activity-wrap { max-width: 720px; animation: fadeUp 0.35s ease both; }

  .activity-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }

  .activity-count {
    font-size: 0.72rem;
    color: var(--text-dim);
    font-family: var(--mono, monospace);
  }

  .timeline {
    position: relative;
    padding-left: 2.4rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 0; bottom: 0;
    width: 1px;
    background: var(--border);
  }

  .timeline-item {
    position: relative;
    padding: 0.85rem 0 0.85rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .timeline-item:last-child { border-bottom: none; }

  .timeline-dot {
    position: absolute;
    left: -1.9rem;
    top: 1.05rem;
    width: 22px; height: 22px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 10px;
    border: 1.5px solid var(--border);
  }

  .dot-key      { background: rgba(73,160,120,0.15); color: #49a078; border-color: rgba(73,160,120,0.35); }
  .dot-user     { background: rgba(139,133,255,0.12); color: #8b85ff; border-color: rgba(139,133,255,0.3); }
  .dot-project  { background: rgba(245,158,11,0.1);  color: #f59e0b; border-color: rgba(245,158,11,0.25); }
  .dot-task     { background: rgba(156,197,161,0.12); color: #9cc5a1; border-color: rgba(156,197,161,0.25); }
  .dot-delete   { background: rgba(224,96,112,0.1);  color: #e06070; border-color: rgba(224,96,112,0.25); }

  .timeline-action {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .timeline-meta {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .timeline-time {
    font-size: 0.68rem;
    color: var(--text-dim);
    font-family: var(--mono, monospace);
  }

  .entity-badge {
    font-family: var(--mono, monospace);
    font-size: 0.58rem;
    padding: 0.1rem 0.38rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background: var(--surface2, #2a3030);
    border: 1px solid var(--border);
    color: var(--text-dim);
  }

  .detail-chip {
    font-size: 0.68rem;
    color: var(--text-dim);
    font-family: var(--mono, monospace);
    background: var(--surface2, #2a3030);
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }

  .empty-timeline {
    text-align: center;
    padding: 3rem 1rem;
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  .pagination {
    display: flex;
    gap: 0.5rem;
    margin-top: 1.2rem;
    justify-content: flex-end;
  }

  .btn-sm {
    font-size: 0.72rem;
    padding: 0.35rem 0.8rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    border: 1px solid var(--border);
    color: var(--text);
    background: var(--surface2, #2a3030);
    cursor: pointer;
  }

  .btn-sm:hover { border-color: var(--violet, #49a078); color: var(--violet, #49a078); }
</style>

<div class="activity-wrap">

  <div class="activity-header">
    <div class="activity-count">
      <%= meta.total %> event<%= meta.total !== 1 ? 's' : '' %> total
    </div>
  </div>

  <% if (!logs || logs.length === 0) { %>
    <div class="empty-timeline">No activity recorded yet.</div>
  <% } else { %>

  <div class="timeline">
    <% const ACTION_LABELS = {
      'key.generated':   'Generated API key',
      'key.revoked':     'Revoked API key',
      'user.login':      'Signed in',
      'user.register':   'Created account',
      'project.created': 'Created project',
      'project.updated': 'Updated project',
      'project.deleted': 'Deleted project',
      'task.created':    'Created task',
      'task.updated':    'Updated task',
      'task.deleted':    'Deleted task',
    }; %>

    <% logs.forEach(entry => {
      const cat    = entry.action.split('.')[0];
      const verb   = entry.action.split('.')[1] || '';
      const isDel  = verb === 'deleted' || verb === 'revoked';
      const dotCls = isDel ? 'dot-delete' : ('dot-' + cat);
      const label  = ACTION_LABELS[entry.action] || entry.action;
      const ts     = new Date(entry.created_at * 1000);
      const timeStr = ts.toLocaleString('en-GB', {
        day: '2-digit', month: 'short', year: 'numeric',
        hour: '2-digit', minute: '2-digit',
      });

      const ICONS = { key: '🔑', user: '👤', project: '📁', task: '✓' };
      const icon  = ICONS[cat] || '•';
    %>
      <div class="timeline-item">
        <div class="timeline-dot <%= dotCls %>"><%= icon %></div>
        <div class="timeline-action"><%= label %></div>
        <div class="timeline-meta">
          <span class="timeline-time"><%= timeStr %></span>
          <% if (entry.entity_type) { %>
            <span class="entity-badge"><%= entry.entity_type %></span>
          <% } %>
          <% if (entry.details?.name) { %>
            <span class="detail-chip"><%= entry.details.name %></span>
          <% } %>
          <% if (entry.details?.title) { %>
            <span class="detail-chip"><%= entry.details.title %></span>
          <% } %>
          <% if (entry.details?.plan) { %>
            <span class="detail-chip"><%= entry.details.plan %></span>
          <% } %>
        </div>
      </div>
    <% }) %>
  </div>

  <% if (meta.total > meta.limit) { %>
    <div class="pagination">
      <% if (meta.offset > 0) { %>
        <a href="/dashboard/activity?offset=<%= Math.max(0, meta.offset - meta.limit) %>" class="btn-sm">Previous</a>
      <% } %>
      <% if (meta.offset + meta.limit < meta.total) { %>
        <a href="/dashboard/activity?offset=<%= meta.offset + meta.limit %>" class="btn-sm">Next</a>
      <% } %>
    </div>
  <% } %>

  <% } %>
</div>
