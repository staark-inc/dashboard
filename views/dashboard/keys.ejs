<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* NEW KEY BANNER */
  .new-key-banner {
    background: rgba(0,229,176,0.05);
    border: 1px solid rgba(0,229,176,0.18);
    border-radius: 12px;
    padding: 1rem 1.2rem;
    margin-bottom: 1.3rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    animation: fadeUp 0.3s ease both;
    flex-wrap: wrap;
  }

  .new-key-icon {
    width: 32px; height: 32px;
    border-radius: 8px;
    background: var(--cyan-dim);
    border: 1px solid rgba(0,229,176,0.2);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    color: var(--cyan);
  }

  .new-key-text { flex: 1; min-width: 0; }
  .new-key-text strong { display: block; font-size: 0.82rem; color: var(--cyan); margin-bottom: 0.15rem; }
  .new-key-text span   { font-size: 0.75rem; color: var(--text-dim); }

  .key-reveal-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--mono);
    font-size: 0.76rem;
    background: var(--surface2);
    border: 1px solid var(--border2);
    border-radius: 8px;
    padding: 0.5rem 0.7rem;
    color: var(--cyan);
    word-break: break-all;
    flex: 1;
    min-width: 0;
    max-width: 440px;
  }

  .key-reveal-text { flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .copy-btn {
    background: none;
    border: 1px solid rgba(0,229,176,0.25);
    border-radius: 6px;
    padding: 0.28rem 0.6rem;
    font-size: 0.7rem;
    color: var(--cyan);
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .copy-btn:hover { background: var(--cyan-dim); }
  .copy-btn.copied { background: var(--cyan-dim); }

  /* LAYOUT */
  .keys-layout {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 1.2rem;
    align-items: start;
    animation: fadeUp 0.35s ease both;
  }

  /* TABLE */
  .keys-table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .table-header {
    display: grid;
    grid-template-columns: 1fr 160px 90px 100px 80px 50px;
    gap: 0.5rem;
    padding: 0.65rem 1.1rem;
    font-family: var(--mono);
    font-size: 0.58rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .key-row {
    display: grid;
    grid-template-columns: 1fr 160px 90px 100px 80px 50px;
    gap: 0.5rem;
    align-items: center;
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--border);
    transition: background 0.12s;
  }

  .key-row:last-child { border-bottom: none; }
  .key-row:hover { background: var(--surface2); }

  .key-name-cell { min-width: 0; }
  .key-name { font-size: 0.82rem; font-weight: 600; color: var(--text); margin-bottom: 0.18rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .key-preview-cell {
    font-family: var(--mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    background: var(--surface2);
    padding: 0.18rem 0.45rem;
    border-radius: 4px;
    border: 1px solid var(--border);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .key-date { font-size: 0.7rem; color: var(--text-dim); font-family: var(--mono); }

  .status-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.28rem;
    font-family: var(--mono);
    font-size: 0.58rem;
    padding: 0.12rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .status-pill .pip { width: 5px; height: 5px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
  .status-pill.active       { color: var(--cyan);   background: var(--cyan-dim);  border: 1px solid rgba(0,229,176,0.2); }
  .status-pill.revoked      { color: var(--red);    background: var(--red-dim);   border: 1px solid rgba(255,77,106,0.2); }
  .label-pill               { display: inline-block; font-family: var(--mono); font-size: 0.58rem; padding: 0.1rem 0.38rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap; }
  .label-pill.production    { color: #f59e0b; background: rgba(245,158,11,0.1); border: 1px solid rgba(245,158,11,0.25); }
  .label-pill.development   { color: var(--cyan);   background: var(--cyan-dim);  border: 1px solid rgba(0,229,176,0.2); }
  .label-pill.read-only     { color: #a78bfa; background: rgba(167,139,250,0.1); border: 1px solid rgba(167,139,250,0.25); }

  .revoke-btn {
    background: none;
    border: 1px solid var(--border2);
    border-radius: 6px;
    padding: 0.24rem 0.5rem;
    font-size: 0.68rem;
    color: var(--text-dim);
    cursor: pointer;
    font-family: var(--sans);
    transition: all 0.12s;
    white-space: nowrap;
  }

  .revoke-btn:hover { border-color: var(--red); color: var(--red); background: var(--red-dim); }

  .empty-state {
    padding: 3rem 1.2rem;
    text-align: center;
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* GENERATE PANEL */
  .generate-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
  }

  .generate-panel-header {
    padding: 0.8rem 1.1rem;
    border-bottom: 1px solid var(--border);
    font-size: 0.82rem;
    font-weight: 600;
    color: #fff;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .generate-panel-body {
    padding: 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .form-group label {
    font-size: 0.73rem;
    font-weight: 500;
    color: var(--text-mid);
  }

  .form-group input,
  .form-group select {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.6rem 0.8rem;
    font-size: 0.82rem;
    color: var(--text);
    font-family: var(--sans);
    outline: none;
    transition: border-color 0.2s;
    width: 100%;
  }

  .form-group input:focus,
  .form-group select:focus { border-color: var(--violet); }

  .form-group input::placeholder { color: var(--text-dim); }
  .form-group select option { background: var(--surface2); }

  .btn-generate {
    background: var(--violet);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 0.62rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    font-family: var(--sans);
    cursor: pointer;
    transition: opacity 0.15s;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
  }

  .btn-generate:hover { opacity: 0.85; }

  .info-box {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem;
    font-size: 0.72rem;
    color: var(--text-dim);
    line-height: 1.55;
  }
</style>

<!-- NEW KEY REVEAL -->
<% if (typeof newKey !== 'undefined' && newKey) { %>
  <div class="new-key-banner">
    <div class="new-key-icon">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6M15.5 7.5l3 3L22 7l-3-3"/>
      </svg>
    </div>
    <div class="new-key-text">
      <strong>Key generated — copy it now</strong>
      <span>This is the only time your full key will be shown.</span>
    </div>
    <div class="key-reveal-row">
      <span class="key-reveal-text" id="keyVal"><%= newKey %></span>
      <button class="copy-btn" id="copyBtn"
              onclick="navigator.clipboard.writeText(document.getElementById('keyVal').textContent).then(() => { this.textContent = 'Copied!'; this.classList.add('copied'); setTimeout(()=>{ this.textContent='Copy'; this.classList.remove('copied'); }, 2000); })">
        Copy
      </button>
    </div>
  </div>
<% } %>

<!-- LAYOUT -->
<div class="keys-layout">

  <!-- TABLE -->
  <div class="keys-table-wrap">
    <% if (!keys || keys.length === 0) { %>
      <div class="empty-state">No API keys yet. Generate one to get started.</div>
    <% } else { %>
      <div class="table-header">
        <span>Name</span>
        <span>Key</span>
        <span>Label</span>
        <span>Created</span>
        <span>Status</span>
        <span></span>
      </div>
      <% keys.forEach(k => { %>
        <div class="key-row">
          <div class="key-name-cell">
            <div class="key-name"><%= k.name || 'Unnamed key' %></div>
          </div>
          <div class="key-preview-cell">sk_live_••••<%= k.lastFour || '••••' %></div>
          <div>
            <span class="label-pill <%= (k.label || 'development').replace(/[^a-z-]/g,'') %>">
              <%= k.label || 'development' %>
            </span>
          </div>
          <div class="key-date"><%= new Date(k.createdAt || k.created_at * 1000).toLocaleDateString('en-GB') %></div>
          <div>
            <span class="status-pill <%= k.revokedAt ? 'revoked' : 'active' %>">
              <span class="pip"></span>
              <%= k.revokedAt ? 'revoked' : 'active' %>
            </span>
          </div>
          <div>
            <% if (!k.revokedAt) { %>
              <button class="revoke-btn"
                      onclick="openConfirm('/dashboard/keys/<%= k.id %>/revoke', '<%= (k.name || 'API key').replace(/'/g, `\\'`) %>', 'This key will be permanently revoked and cannot be re-activated.')">
                Revoke
              </button>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

  <!-- GENERATE PANEL -->
  <div class="generate-panel">
    <div class="generate-panel-header">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--violet)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6M15.5 7.5l3 3L22 7l-3-3"/>
      </svg>
      Generate new key
    </div>
    <div class="generate-panel-body">
      <form action="/dashboard/keys/generate" method="POST" style="display:contents">
        <div class="form-group">
          <label>Key name</label>
          <input type="text" name="name" placeholder="e.g. Production, Mobile app" required />
        </div>
        <div class="form-group">
          <label>Label</label>
          <select name="label">
            <option value="development">Development</option>
            <option value="production">Production</option>
            <option value="read-only">Read-only</option>
          </select>
        </div>
        <div class="form-group">
          <label>Plan</label>
          <select name="plan">
            <option value="free">Free — 300 req/day</option>
            <option value="pro">Pro — 2,500 req/day</option>
            <option value="enterprise">Enterprise — 5,000 req/day</option>
          </select>
        </div>
        <button type="submit" class="btn-generate">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="7.5" cy="15.5" r="5.5"/><path d="M21 2l-9.6 9.6M15.5 7.5l3 3L22 7l-3-3"/>
          </svg>
          Generate key
        </button>
      </form>
      <div class="info-box">
        API keys give full access to the Staark API on behalf of your account. Keep them secret and never commit them to source control.
      </div>
    </div>
  </div>

</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div style="margin-top:1rem;background:var(--red-dim);border:1px solid rgba(255,77,106,0.2);border-radius:8px;padding:0.7rem 1rem;font-size:0.78rem;color:var(--red)"><%= error %></div>
<% } %>
