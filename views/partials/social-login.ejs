<div class="social-login">
  <% providers.forEach(p => { %>
    <a href="<%= p.url %>" class="btn <%= p.class %>">
      <img src="<%= p.icon %>" />
      <%= p.label %>
    </a>
  <% }) %>
</div>

<style>
.social-login {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.social-login .btn {
  display: flex;
  align-items: center;
  gap: 0.8rem;
  padding: 0.6rem 1.2rem;
  border: 1px solid var(--border);
  border-radius: 4px;
  text-decoration: none;
  color: var(--text);
  font-weight: 500;
}

.social-login .btn img {
  width: 20px;
  height: 20px;
}

.social-login .btn.google { background: #fff; }
.social-login .btn.github { background: #333; color: #fff; }
</style>